---
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import { url } from '../utils/base';

interface Props {
  title: string;
  description: string;
  ogImage?: string;
  breadcrumbs?: { label: string; href?: string }[];
  canonicalUrl?: string;
  schemas?: Record<string, unknown>[];
}

const { title, description, ogImage, breadcrumbs, canonicalUrl, schemas } = Astro.props;
const siteUrl = 'https://avis-agences-digitales.fr';
const currentUrl = canonicalUrl || new URL(Astro.url.pathname, siteUrl).href;
const ogImg = ogImage || `${siteUrl}/images/og-default.jpg`;

const websiteSchema = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  "name": "Avis Agences Digitales",
  "url": siteUrl,
  "description": "Plateforme de référence pour les avis clients vérifiés sur les agences web et SEO en France.",
  "inLanguage": "fr-FR",
  "publisher": {
    "@type": "Organization",
    "name": "Avis Agences Digitales",
    "url": siteUrl
  }
};

const organizationSchema = {
  "@context": "https://schema.org",
  "@type": "Organization",
  "name": "Avis Agences Digitales",
  "url": siteUrl,
  "description": "Plateforme indépendante d'avis clients vérifiés sur les agences web et SEO en France.",
  "foundingDate": "2024",
  "sameAs": []
};
---
<!DOCTYPE html>
<html lang="fr">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={currentUrl} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={currentUrl} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImg} />
  <meta property="og:locale" content="fr_FR" />
  <meta property="og:site_name" content="Avis Agences Digitales" />

  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" content={title} />
  <meta name="twitter:description" content={description} />
  <meta name="twitter:image" content={ogImg} />

  <!-- Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />

  <link rel="icon" type="image/svg+xml" href={url('/favicon.svg')} />

  <!-- Schema.org : WebSite + Organization -->
  <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(organizationSchema)} />

  <!-- Schema.org : BreadcrumbList -->
  {breadcrumbs && breadcrumbs.length > 0 && (
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "BreadcrumbList",
      "itemListElement": breadcrumbs.map((crumb, index) => ({
        "@type": "ListItem",
        "position": index + 1,
        "name": crumb.label,
        ...(crumb.href ? { "item": `${siteUrl}${crumb.href}` } : {})
      }))
    })} />
  )}

  <!-- Schema.org : page-specific -->
  {schemas && schemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <slot name="head" />
</head>
<body class="min-h-screen flex flex-col">
  <Header />
  {breadcrumbs && breadcrumbs.length > 0 && <Breadcrumb items={breadcrumbs} />}
  <main class="flex-1">
    <slot />
  </main>
  <Footer />
</body>
</html>
