---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const breadcrumbs = [
  { label: 'Accueil', href: '/' },
  { label: 'Blog' },
];
---
<BaseLayout
  title="Blog — Conseils et guides pour choisir votre agence web"
  description="Articles et guides pratiques pour bien choisir votre agence web ou SEO. Conseils d'experts, comparatifs et retours d'expérience."
  breadcrumbs={breadcrumbs}
>
  <section class="py-8 md:py-12">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-2xl md:text-4xl font-extrabold mb-4">Blog</h1>
      <p class="text-lg text-gray-600 mb-10">
        Conseils, guides et analyses pour vous aider à choisir la meilleure agence web pour votre projet.
      </p>
      <div class="space-y-8">
        {posts.map(post => (
          <article class="border-b border-gray-200 pb-8">
            <a href={`/blog/${post.id.replace(/\.md$/, '')}`} class="group">
              <h2 class="text-xl md:text-2xl font-bold text-gray-900 group-hover:text-primary transition-colors mb-2">
                {post.data.title}
              </h2>
              <p class="text-sm text-gray-500 mb-3">
                {new Date(post.data.date).toLocaleDateString('fr-FR', { year: 'numeric', month: 'long', day: 'numeric' })}
                {' '}&mdash;{' '}{post.data.author}
              </p>
              <p class="text-gray-600">{post.data.description}</p>
              <span class="inline-block mt-3 text-primary font-medium text-sm group-hover:underline">
                Lire la suite &rarr;
              </span>
            </a>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
