---
import BaseLayout from '../layouts/BaseLayout.astro';
import { url } from '../utils/base';

const breadcrumbs = [
  { label: 'Accueil', href: url('/') },
  { label: 'Contact' },
];
---
<BaseLayout
  title="Contact — Avis Agences Digitales"
  description="Contactez l'équipe d'Avis-Agences-Digitales.fr pour soumettre un avis, signaler une erreur ou toute autre demande."
  breadcrumbs={breadcrumbs}
>
  <section class="py-8 md:py-16">
    <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8">
      <h1 class="text-2xl md:text-4xl font-extrabold mb-4">Contactez-nous</h1>
      <p class="text-gray-600 mb-8">
        Une question, un avis à soumettre ou une suggestion ? Remplissez le formulaire ci-dessous et notre équipe vous répondra dans les plus brefs délais.
      </p>

      <form class="space-y-6" action="#" method="POST">
        <div>
          <label for="nom" class="block text-sm font-medium text-gray-700 mb-1">Nom complet</label>
          <input type="text" id="nom" name="nom" required
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-primary text-sm" />
        </div>
        <div>
          <label for="email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input type="email" id="email" name="email" required
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-primary text-sm" />
        </div>
        <div>
          <label for="sujet" class="block text-sm font-medium text-gray-700 mb-1">Sujet</label>
          <select id="sujet" name="sujet"
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-primary text-sm bg-white">
            <option value="avis">Soumettre un avis</option>
            <option value="erreur">Signaler une erreur</option>
            <option value="agence">Référencer mon agence</option>
            <option value="autre">Autre demande</option>
          </select>
        </div>
        <div>
          <label for="message" class="block text-sm font-medium text-gray-700 mb-1">Message</label>
          <textarea id="message" name="message" rows="5" required
            class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-primary text-sm"></textarea>
        </div>
        <button type="submit"
          class="bg-primary hover:bg-primary-dark text-white font-semibold px-8 py-3 rounded-lg transition-colors w-full sm:w-auto">
          Envoyer le message
        </button>
      </form>
    </div>
  </section>
</BaseLayout>
