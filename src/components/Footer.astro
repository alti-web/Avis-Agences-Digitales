---
const currentYear = new Date().getFullYear();
---
<footer class="bg-gray-900 text-gray-400 mt-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <div>
        <h3 class="text-white font-semibold text-lg mb-4">Avis Agences Digitales</h3>
        <p class="text-sm leading-relaxed">
          La plateforme de référence pour consulter les avis clients sur les agences web et SEO en France.
        </p>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Navigation</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/" class="hover:text-white transition-colors">Accueil</a></li>
          <li><a href="/blog" class="hover:text-white transition-colors">Blog</a></li>
          <li><a href="/methodologie" class="hover:text-white transition-colors">Méthodologie</a></li>
          <li><a href="/a-propos" class="hover:text-white transition-colors">À propos</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Contact</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Villes populaires</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/agences-web/paris" class="hover:text-white transition-colors">Agences web Paris</a></li>
          <li><a href="/agences-web/lyon" class="hover:text-white transition-colors">Agences web Lyon</a></li>
          <li><a href="/agences-web/marseille" class="hover:text-white transition-colors">Agences web Marseille</a></li>
          <li><a href="/agences-web/bordeaux" class="hover:text-white transition-colors">Agences web Bordeaux</a></li>
          <li><a href="/agences-web/grenoble" class="hover:text-white transition-colors">Agences web Grenoble</a></li>
        </ul>
      </div>
      <div>
        <h4 class="text-white font-semibold mb-4">Informations</h4>
        <ul class="space-y-2 text-sm">
          <li><a href="/mentions-legales" class="hover:text-white transition-colors">Mentions légales</a></li>
          <li><a href="/contact" class="hover:text-white transition-colors">Nous contacter</a></li>
        </ul>
      </div>
    </div>
    <div class="border-t border-gray-800 mt-8 pt-8 text-center text-sm">
      <p>&copy; {currentYear} Avis-Agences-Digitales.fr — Tous droits réservés.</p>
    </div>
  </div>
</footer>
