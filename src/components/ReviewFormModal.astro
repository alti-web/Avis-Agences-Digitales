---
interface Props {
  agenceNom: string;
}
const { agenceNom } = Astro.props;
---

<!-- Modal overlay -->
<div id="review-modal" class="fixed inset-0 z-50 hidden">
  <div id="review-overlay" class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>

  <div class="relative flex items-center justify-center min-h-screen p-4">
    <div class="relative bg-white rounded-xl shadow-2xl w-full max-w-lg p-6 md:p-8 animate-modal">

      <!-- Bouton fermer -->
      <button id="review-close" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 transition-colors" aria-label="Fermer">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>

      <!-- Formulaire -->
      <div id="review-form-container">
        <h3 class="text-xl md:text-2xl font-bold mb-6">Laisser un avis sur {agenceNom}</h3>

        <form id="review-form" class="space-y-5">
          <div>
            <label for="review-nom" class="block text-sm font-medium text-gray-700 mb-1">Nom complet</label>
            <input type="text" id="review-nom" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-primary text-sm"
              placeholder="Votre nom" />
          </div>

          <div>
            <label for="review-email" class="block text-sm font-medium text-gray-700 mb-1">Email</label>
            <input type="email" id="review-email" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-primary text-sm"
              placeholder="votre@email.com" />
          </div>

          <div>
            <label class="block text-sm font-medium text-gray-700 mb-2">Note</label>
            <div id="star-selector" class="flex gap-1">
              <button type="button" data-star="1" class="star-btn text-gray-300 hover:text-star transition-colors" aria-label="1 étoile">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </button>
              <button type="button" data-star="2" class="star-btn text-gray-300 hover:text-star transition-colors" aria-label="2 étoiles">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </button>
              <button type="button" data-star="3" class="star-btn text-gray-300 hover:text-star transition-colors" aria-label="3 étoiles">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </button>
              <button type="button" data-star="4" class="star-btn text-gray-300 hover:text-star transition-colors" aria-label="4 étoiles">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </button>
              <button type="button" data-star="5" class="star-btn text-gray-300 hover:text-star transition-colors" aria-label="5 étoiles">
                <svg class="w-8 h-8" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" /></svg>
              </button>
            </div>
            <input type="hidden" id="review-note" value="0" />
          </div>

          <div>
            <label for="review-texte" class="block text-sm font-medium text-gray-700 mb-1">Votre avis</label>
            <textarea id="review-texte" rows="4" required
              class="w-full border border-gray-300 rounded-lg px-4 py-2.5 focus:ring-2 focus:ring-primary focus:border-primary text-sm"
              placeholder="Décrivez votre expérience avec cette agence..."></textarea>
          </div>

          <div class="flex gap-3 justify-end pt-2">
            <button type="button" id="review-cancel"
              class="px-6 py-2.5 rounded-lg border border-gray-300 text-gray-700 font-medium text-sm hover:bg-gray-50 transition-colors">
              Annuler
            </button>
            <button type="submit" id="review-submit"
              class="bg-primary hover:bg-primary-dark text-white font-semibold px-6 py-2.5 rounded-lg transition-colors text-sm flex items-center gap-2">
              Envoyer l'avis
            </button>
          </div>
        </form>
      </div>

      <!-- Message de succès -->
      <div id="review-success" class="hidden text-center py-8">
        <div class="w-16 h-16 bg-green-100 rounded-full flex items-center justify-center mx-auto mb-4">
          <svg class="w-8 h-8 text-green-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
          </svg>
        </div>
        <h3 class="text-xl font-bold text-gray-900 mb-2">Merci pour votre avis !</h3>
        <p class="text-gray-600 text-sm">Votre avis a bien été envoyé. Il sera publié après vérification par notre équipe.</p>
      </div>

    </div>
  </div>
</div>

<style>
  .animate-modal {
    animation: modalIn 0.2s ease-out;
  }
  @keyframes modalIn {
    from { opacity: 0; transform: scale(0.95) translateY(10px); }
    to { opacity: 1; transform: scale(1) translateY(0); }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const modal = document.getElementById('review-modal');
    const overlay = document.getElementById('review-overlay');
    const closeBtn = document.getElementById('review-close');
    const cancelBtn = document.getElementById('review-cancel');
    const form = document.getElementById('review-form') as HTMLFormElement;
    const formContainer = document.getElementById('review-form-container');
    const successDiv = document.getElementById('review-success');
    const submitBtn = document.getElementById('review-submit') as HTMLButtonElement;
    const noteInput = document.getElementById('review-note') as HTMLInputElement;
    const starBtns = document.querySelectorAll('.star-btn');
    const openBtn = document.getElementById('open-review-modal');

    let selectedNote = 0;

    function openModal() {
      modal?.classList.remove('hidden');
      document.body.style.overflow = 'hidden';
    }

    function closeModal() {
      modal?.classList.add('hidden');
      document.body.style.overflow = '';
      form?.reset();
      selectedNote = 0;
      updateStars(0);
      formContainer?.classList.remove('hidden');
      successDiv?.classList.add('hidden');
      if (submitBtn) {
        submitBtn.disabled = false;
        submitBtn.innerHTML = 'Envoyer l\'avis';
      }
    }

    function updateStars(n: number) {
      starBtns.forEach((btn, i) => {
        if (i < n) {
          btn.classList.add('text-star');
          btn.classList.remove('text-gray-300');
        } else {
          btn.classList.remove('text-star');
          btn.classList.add('text-gray-300');
        }
      });
    }

    openBtn?.addEventListener('click', openModal);
    overlay?.addEventListener('click', closeModal);
    closeBtn?.addEventListener('click', closeModal);
    cancelBtn?.addEventListener('click', closeModal);

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !modal?.classList.contains('hidden')) {
        closeModal();
      }
    });

    starBtns.forEach((btn) => {
      btn.addEventListener('click', () => {
        selectedNote = parseInt((btn as HTMLElement).dataset.star || '0');
        updateStars(selectedNote);
        if (noteInput) noteInput.value = selectedNote.toString();
      });

      btn.addEventListener('mouseenter', () => {
        const n = parseInt((btn as HTMLElement).dataset.star || '0');
        updateStars(n);
      });
    });

    document.getElementById('star-selector')?.addEventListener('mouseleave', () => {
      updateStars(selectedNote);
    });

    form?.addEventListener('submit', (e) => {
      e.preventDefault();

      if (selectedNote === 0) {
        alert('Veuillez sélectionner une note.');
        return;
      }

      if (submitBtn) {
        submitBtn.disabled = true;
        submitBtn.innerHTML = '<svg class="w-4 h-4 animate-spin" fill="none" viewBox="0 0 24 24"><circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle><path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4z"></path></svg> Envoi en cours…';
      }

      setTimeout(() => {
        formContainer?.classList.add('hidden');
        successDiv?.classList.remove('hidden');

        setTimeout(closeModal, 3000);
      }, 1500);
    });
  });
</script>
