---
interface Props {
  note: number;
  size?: 'sm' | 'md' | 'lg';
  showValue?: boolean;
}

const { note, size = 'md', showValue = true } = Astro.props;

const sizeClasses = {
  sm: 'w-4 h-4',
  md: 'w-5 h-5',
  lg: 'w-6 h-6',
};

const textClasses = {
  sm: 'text-sm',
  md: 'text-base',
  lg: 'text-lg',
};

const stars = Array.from({ length: 5 }, (_, i) => {
  const diff = note - i;
  if (diff >= 1) return 'full';
  if (diff >= 0.5) return 'half';
  return 'empty';
});
---
<div class="flex items-center gap-1">
  {stars.map((type) => (
    <svg class={`${sizeClasses[size]} ${type === 'empty' ? 'text-star-empty' : 'text-star'}`} fill="currentColor" viewBox="0 0 20 20">
      {type === 'half' ? (
        <Fragment>
          <defs>
            <linearGradient id="half-star">
              <stop offset="50%" stop-color="currentColor" />
              <stop offset="50%" stop-color="#d1d5db" />
            </linearGradient>
          </defs>
          <path fill="url(#half-star)" d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </Fragment>
      ) : (
        <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
      )}
    </svg>
  ))}
  {showValue && <span class={`font-semibold text-gray-700 ml-1 ${textClasses[size]}`}>{note.toFixed(1)}</span>}
</div>
