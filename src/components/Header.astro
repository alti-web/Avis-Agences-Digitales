---
import { url } from '../utils/base';
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---
<header class="bg-primary text-white shadow-lg">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex items-center justify-between h-16">
      <a href={url('/')} class="flex items-center gap-2 font-bold text-xl hover:text-gray-200 transition-colors">
        <svg class="w-8 h-8 text-star" fill="currentColor" viewBox="0 0 20 20">
          <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z" />
        </svg>
        <span>Avis Agences Digitales</span>
      </a>
      <nav class="hidden md:flex items-center gap-6">
        <a href={url('/')} class:list={["hover:text-gray-200 transition-colors text-sm font-medium", { "text-star": currentPath === `${base}/` || currentPath === base }]}>Accueil</a>
        <a href={url('/blog')} class:list={["hover:text-gray-200 transition-colors text-sm font-medium", { "text-star": currentPath.startsWith(`${base}/blog`) }]}>Blog</a>
        <a href={url('/methodologie')} class:list={["hover:text-gray-200 transition-colors text-sm font-medium", { "text-star": currentPath.startsWith(`${base}/methodologie`) }]}>Méthodologie</a>
        <a href={url('/a-propos')} class:list={["hover:text-gray-200 transition-colors text-sm font-medium", { "text-star": currentPath.startsWith(`${base}/a-propos`) }]}>À propos</a>
        <a href={url('/contact')} class:list={["hover:text-gray-200 transition-colors text-sm font-medium", { "text-star": currentPath.startsWith(`${base}/contact`) }]}>Contact</a>
      </nav>
      <button id="mobile-menu-btn" class="md:hidden p-2" aria-label="Menu">
        <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
    <nav id="mobile-menu" class="hidden md:hidden pb-4">
      <div class="flex flex-col gap-2">
        <a href={url('/')} class="py-2 hover:text-gray-200 transition-colors text-sm">Accueil</a>
        <a href={url('/blog')} class="py-2 hover:text-gray-200 transition-colors text-sm">Blog</a>
        <a href={url('/methodologie')} class="py-2 hover:text-gray-200 transition-colors text-sm">Méthodologie</a>
        <a href={url('/a-propos')} class="py-2 hover:text-gray-200 transition-colors text-sm">À propos</a>
        <a href={url('/contact')} class="py-2 hover:text-gray-200 transition-colors text-sm">Contact</a>
      </div>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => {
    menu?.classList.toggle('hidden');
  });
</script>
